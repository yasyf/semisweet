# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local environment
.env*

# Claude Code
.context/
.claude/settings.local.json

# Python bytecode (guard hooks are Python even in non-Python repos)
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Compiled extension built in-place into the package source by `maturin develop`/`build`
# (mixed layout: module-name = "semisweet.core", python-source = "python").
/python/semisweet/*.so
/python/semisweet/*.pyd

# Rust
/target
# Cargo.lock is intentionally committed (this crate ships a wheel; reproducible
# builds) — do not ignore it.

# Downloaded model caches (regenerable; fastembed/ONNX weights)
.fastembed_cache/
target/
