{
  "effortLevel": "max",
  "ultracode": true,
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "includeGitInstructions": false,
  "disableArtifact": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "JJ_CONFIG": ".claude/jj-config.toml",
    "TY_OUTPUT_FORMAT": "concise",
    "TY_CONFIG_FILE": ".claude/ty-quiet.toml"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(uv build:*)",
      "Bash(uv lock:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)"
    ],
    "defaultMode": "auto"
  },
  "extraKnownMarketplaces": {
    "skills": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-skills"
      },
      "autoUpdate": true
    },
    "cc-notes": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-notes"
      },
      "autoUpdate": true
    },
    "cc-context": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-context"
      },
      "autoUpdate": true
    },
    "captain-hook": {
      "source": {
        "source": "github",
        "repo": "yasyf/captain-hook"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "codex@skills": true,
    "slop-cop@skills": true,
    "llm-prompts@skills": true,
    "writing-docs@skills": true,
    "cc-context@cc-context": true,
    "cc-notes@cc-notes": true,
    "captain-hook@captain-hook": true
  }
}
