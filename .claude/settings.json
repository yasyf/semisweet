{
  "effortLevel": "max",
  "ultracode": true,
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "includeGitInstructions": false,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "TY_OUTPUT_FORMAT": "concise",
    "JJ_CONFIG": ".claude/jj-config.toml"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(wc:*)"
    ],
    "defaultMode": "auto"
  },
  "extraKnownMarketplaces": {
    "skills": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-skills"
      },
      "autoUpdate": true
    },
    "captain-hook": {
      "source": {
        "source": "github",
        "repo": "yasyf/captain-hook"
      }
    },
    "cc-notes": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-notes"
      }
    }
  },
  "enabledPlugins": {
    "codex@skills": true,
    "slop-cop@skills": true,
    "llm-prompts@skills": true,
    "writing-docs@skills": true,
    "captain-hook@captain-hook": true,
    "cc-notes@cc-notes": true
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PermissionRequest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PostToolUse"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PostToolUseFailure"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PreToolUse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run SessionStart --async",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run Stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run UserPromptSubmit"
          }
        ]
      }
    ]
  }
}
